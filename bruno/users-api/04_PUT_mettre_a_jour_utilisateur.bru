meta {
  name: 04 - PUT mettre à jour un utilisateur
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/users/{{newUserId}}
  body: json
  auth: none
}

body:json {
  {
    "name": "David Bernard Modifié",
    "role": "admin"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.name: eq David Bernard Modifié
  res.body.data.role: eq admin
}
