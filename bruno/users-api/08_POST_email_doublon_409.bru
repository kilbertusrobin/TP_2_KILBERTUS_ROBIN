meta {
  name: 08 - POST email doublon (409)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/users
  body: json
  auth: none
}

body:json {
  {
    "name": "Doublon Alice",
    "email": "alice@example.com"
  }
}

assert {
  res.status: eq 409
  res.body.success: eq false
  res.body.message: eq Cet email est déjà utilisé
}
